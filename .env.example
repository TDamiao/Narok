# Base RPC endpoint (used for WEB3_HTTP_PROVIDER_URI)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-key

# Deployment credentials (choose one approach)
# Option A: load a local Ape account by alias
APE_ACCOUNT_ALIAS=narok-deployer
# Option B: provide a raw private key (never commit real secrets)
PRIVATE_KEY=0xabc123...

# Vault roles
ADMIN_WALLET=0x0000000000000000000000000000000000000000
MANAGER_WALLET=0x0000000000000000000000000000000000000000

# Token addresses (Base mainnet defaults)
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# External NAV updater
VAULT_ADDRESS=0x0000000000000000000000000000000000000000
PORTFOLIO_WALLET=0x0000000000000000000000000000000000000000
PORTFOLIO_CONFIG=portfolio.tokens.json
